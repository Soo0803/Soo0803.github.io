---
import MediaBox from './MediaBox.astro';
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].beyond;
const f = t.facets;
---
<section id="beyond">
  <div class="wrap">
    <div class="row reveal">
      <div class="body">
        <p class="eyebrow">{t.eyebrow}</p>
        <h2>{t.title}</h2>
      </div>
    </div>
    <div class="row reveal">
      <div class="body">
        <div class="facets">
          <div class="facet">
            <span class="tag">{f.football.tag}</span>
            <h3>{f.football.title}</h3>
            <p>{f.football.prose}</p>
          </div>
          <div class="facet">
            <span class="tag">{f.isa.tag}</span>
            <h3>{f.isa.title}</h3>
            <p>{f.isa.prose}</p>
          </div>
          <div class="facet">
            <span class="tag">{f.builder.tag}</span>
            <h3>{f.builder.title}</h3>
            <p>{f.builder.prose}</p>
          </div>
        </div>

        <div class="currently">
          <span class="tag">{t.currently.tag}</span>
          <ul>
            {t.currently.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="gallery">
          <MediaBox
            type="image"
            shape="wide"
            src="/media/football.jpg"
            alt="Wei Jie playing football on the pitch"
            block={false}
          />
          <MediaBox
            type="image"
            shape="wide"
            src="/media/isa_pic.jpeg"
            alt="Wei Jie serving as ISA Vice President at an event"
            block={false}
          />
        </div>
      </div>
    </div>
  </div>
</section>
