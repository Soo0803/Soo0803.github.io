---
import MediaBox from './MediaBox.astro';
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].beyond;
const f = t.facets;
---
<section id="beyond">
  <div class="wrap">
    <div class="row reveal">
      <div class="body">
        <p class="eyebrow">{t.eyebrow}</p>
        <h2>{t.title}</h2>
      </div>
    </div>
    <div class="row reveal">
      <div class="body">
        <div class="facets">
          <div class="facet">
            <span class="tag">{f.football.tag}</span>
            <h3>{f.football.title}</h3>
            <p>{f.football.prose}</p>
          </div>
          <div class="facet">
            <span class="tag">{f.builder.tag}</span>
            <h3>{f.builder.title}</h3>
            <p>{f.builder.prose}</p>
          </div>
        </div>

        <div class="currently">
          <span class="tag">{t.currently.tag}</span>
          <ul>
            {t.currently.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <!-- 
          To drop candid photos here (football, travel, lab, friends):
          1. Place files in public/media/
          2. Set type="image" and src="/media/filename.jpg"
          3. You can add more MediaBox components here, the grid will automatically handle any number.
        -->
        <div class="gallery">
          <MediaBox
            type="empty"
            shape="shot"
            label={t.gallery.label}
            hint={t.gallery.hint1}
            block={false}
            icon="image"
          />
          <MediaBox
            type="empty"
            shape="shot"
            label={t.gallery.label}
            hint={t.gallery.hint2}
            block={false}
            icon="image"
          />
        </div>
      </div>
    </div>
  </div>
</section>
