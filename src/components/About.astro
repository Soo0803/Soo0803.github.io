---
import MarginNote from './MarginNote.astro';
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].about;
---
<section id="about">
  <div class="wrap">
    <div class="row reveal">
      <div class="body">
        <p class="eyebrow">{t.eyebrow}</p>
        <h2>{t.title}</h2>
      </div>
    </div>
    <div class="row reveal">
      <div class="body prose">
        <p>{t.prose1}</p>
        <p>
          {t.prose2_part1}<span class="mark">{t.prose2_highlight}</span>{t.prose2_part2}
        </p>
        <p>{t.prose3}</p>
      </div>
      <MarginNote label={t.marginNoteLabel}>
        {t.marginNote}
      </MarginNote>
    </div>
  </div>
</section>
