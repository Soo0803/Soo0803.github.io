---
import MediaBox from './MediaBox.astro';
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].hero;
---
<header class="hero">
  <div class="wrap">
    <div class="hero-inner">
      <div class="hero-text">
        <h1 data-animate>
          <span class="hero-line">{t.line1}</span>
          <span class="hero-line">{t.line2}</span>
          {lang === 'en' ? (
            <span class="hero-line">I {t.line3}</span>
          ) : (
            <span class="hero-line">让我{t.line3}</span>
          )}
        </h1>
        <p class="lede" data-animate>
          {t.lede} <span class="soft">{t.ledeHighlight}</span>
        </p>
        <nav class="links" data-animate>
          <a href="#about">{t.readOn}</a>
          <!-- EMAIL PLACEHOLDER -->
          <a href="mailto:sooweijie@example.com">{t.email}</a>
          <!-- GITHUB LINK (CORRECT) -->
          <a href="https://github.com/Soo0803" target="_blank" rel="noopener">{t.github}</a>
          <!-- LINKEDIN LINK (CORRECT) -->
          <a href="https://www.linkedin.com/in/wei-jie-soo-291921234" target="_blank" rel="noopener">{t.linkedin}</a>
          <!-- RESUME PLACEHOLDER -->
          <a href="#resume">{t.resume}</a>
        </nav>
      </div>

      <div class="hero-portrait" data-animate>
        <!-- 
          To swap in a real portrait photo:
          1. Drop your vertical photo (e.g. portrait.jpg) in public/media/
          2. Change type to "image" and set src to "/media/portrait.jpg"
          3. Set alt="Wei Jie"
        -->
        <MediaBox
          type="image"
          shape="portrait"
          src="/media/profile_photo.JPG"
          alt={lang === 'en' ? "Wei Jie" : "伟捷"}
          block={false}
        />
      </div>
    </div>
  </div>
</header>
