---
interface Props {
  type?: 'empty' | 'image' | 'video' | 'embed';
  src?: string;
  alt?: string;
  poster?: string;
  caption?: string;
  shape?: 'portrait' | 'wide' | 'shot';
  label?: string;
  hint?: string;
  icon?: 'image' | 'video';
  block?: boolean;
  class?: string;
}

const {
  type = 'empty',
  src,
  alt = '',
  poster,
  caption,
  shape = 'shot',
  label,
  hint,
  icon = 'image',
  block = true,
  class: className = '',
} = Astro.props;

// Determine if we wrap in .media-block
const shouldWrap = block || caption;
---

{shouldWrap ? (
  <div class="media-block">
    <figure class:list={["media", shape, { empty: type === 'empty' }, className]} style="margin: 0;">
      {type === 'empty' && (
        <>
          {icon === 'video' ? (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="9" />
              <path d="M10 8.5l6 3.5-6 3.5z" fill="currentColor" stroke="none" />
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="16" rx="2" />
              <circle cx="8.5" cy="9.5" r="1.7" />
              <path d="M21 15.5l-5-5L4.5 21" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          )}
          {label && <span class="ph-label">{label}</span>}
          {hint && <p class="ph-hint">{hint}</p>}
        </>
      )}
      
      {/* 
        To swap in a real image:
        1. Drop your image (e.g. image.png) in public/media/
        2. Set type="image" and src="/media/image.png"
      */}
      {type === 'image' && (
        <img src={src} alt={alt} loading="lazy" />
      )}
      
      {/* 
        To swap in a real video:
        1. Drop your video (e.g. video.mp4) and optional poster (e.g. poster.png) in public/media/
        2. Set type="video", src="/media/video.mp4", and poster="/media/poster.png"
      */}
      {type === 'video' && (
        <video src={src} poster={poster} controls></video>
      )}
      
      {/* 
        To swap in a YouTube/Vimeo embed:
        1. Set type="embed" and src="https://www.youtube.com/embed/VIDEO_ID"
      */}
      {type === 'embed' && (
        <iframe src={src} allowfullscreen></iframe>
      )}
    </figure>
    {caption && <figcaption>{caption}</figcaption>}
  </div>
) : (
  <div class:list={["media", shape, { empty: type === 'empty' }, className]}>
    {type === 'empty' && (
      <>
        {icon === 'video' ? (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="9" />
            <path d="M10 8.5l6 3.5-6 3.5z" fill="currentColor" stroke="none" />
          </svg>
        ) : (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <circle cx="8.5" cy="9.5" r="1.7" />
            <path d="M21 15.5l-5-5L4.5 21" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        )}
        {label && <span class="ph-label">{label}</span>}
        {hint && <p class="ph-hint">{hint}</p>}
      </>
    )}
    
    {type === 'image' && (
      <img src={src} alt={alt} loading="lazy" />
    )}
    
    {type === 'video' && (
      <video src={src} poster={poster} controls></video>
    )}
    
    {type === 'embed' && (
      <iframe src={src} allowfullscreen></iframe>
    )}
  </div>
)}
