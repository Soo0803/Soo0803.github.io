---
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].footer;
const currentYear = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <p class="fine">{t.fine} <span id="year">{currentYear}</span></p>
  </div>
</footer>
