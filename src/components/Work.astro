---
import ProjectEntry from './ProjectEntry.astro';
import MediaBox from './MediaBox.astro';
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].work;
const p = t.projects;
---
<section id="work">
  <div class="wrap">
    <div class="row reveal">
      <div class="body">
        <p class="eyebrow">{t.eyebrow}</p>
        <h2>{t.title}</h2>
      </div>
    </div>

    {/* Project 1: Robot Hand */}
    <ProjectEntry
      kicker={p.robotHand.kicker}
      title={p.robotHand.title}
      meta={p.robotHand.meta}
      lang={lang}
    >
      <p>{p.robotHand.p1}</p>
      <p>{p.robotHand.p2}</p>
      
      <!-- 
        To swap in a real video file (mp4):
        1. Set type="video" and src="/media/robot-hand.mp4"
        2. Set poster="/media/robot-hand-poster.png" (optional)
        3. Add a caption="The hand tracking my fingers in simulation."
      -->
      <MediaBox
        slot="media"
        type="video"
        shape="wide"
        src="/media/Robotics_hand_simulation.mov"
      />
    </ProjectEntry>

    {/* Project 2: Terny */}
    <ProjectEntry
      kicker={p.terny.kicker}
      title={p.terny.title}
      liveUrl="https://terny.ai"
      meta={p.terny.meta}
      noteLabel={p.terny.noteLabel}
      lang={lang}
    >
      <p>{p.terny.p1_part1}</p>
      <p>{p.terny.p1_part2_1}<span class="mark">{p.terny.p1_part2_highlight}</span>{p.terny.p1_part2_2}</p>
      
      <!-- 
        To swap in a real screenshot, video, or iframe:
        1. Set type="image" and src="/media/terny.png"
        2. Set alt="Terny screenshot"
        3. Add a caption="Terny matching a student to research in seconds."
      -->
      <MediaBox
        slot="media"
        type="image"
        shape="wide"
        src="/media/terny_demo.png"
        alt="Terny platform dashboard showing search and outreach agents"
        class="terny-media"
      />
      
      <Fragment slot="note">
        {p.terny.note}
      </Fragment>
    </ProjectEntry>

    {/* Project 3: Cross-border store */}
    <ProjectEntry
      kicker={p.ecommerce.kicker}
      title={p.ecommerce.title}
      meta={p.ecommerce.meta}
      noteLabel={p.ecommerce.noteLabel}
      lang={lang}
    >
      <p>{p.ecommerce.p1}</p>
      <p>{p.ecommerce.p2_1}<span class="mark">{p.ecommerce.p2_highlight}</span>{p.ecommerce.p2_2}</p>
      
      <Fragment slot="note">
        {p.ecommerce.note}
      </Fragment>
    </ProjectEntry>

    {/* Project 4: Undergraduate Research */}
    <ProjectEntry
      kicker={p.research.kicker}
      title={p.research.title}
      meta={p.research.meta}
      noteLabel={p.research.noteLabel}
      lang={lang}
    >
      <p>{p.research.p1}</p>
      <p>{p.research.p2}</p>
      
      <MediaBox
        slot="media"
        type="image"
        shape="wide"
        src="/media/pace_research.jpg"
        alt="Undergraduate research prototype development and testing"
      />
      
      <Fragment slot="note">
        {p.research.note}
      </Fragment>
    </ProjectEntry>

    {/* Project 5: RISC-V Processor */}
    <ProjectEntry
      kicker={p.processor.kicker}
      title={p.processor.title}
      meta={p.processor.meta}
      noteLabel={p.processor.noteLabel}
      lang={lang}
    >
      <p>{p.processor.p1}</p>
      
      <!-- 
        To swap in an architecture diagram or waveform image:
        1. Set type="image" and src="/media/processor-diagram.png"
        2. Set alt="Processor block diagram"
      -->
      <MediaBox
        slot="media"
        type="image"
        shape="wide"
        src="/media/470computer_arch.jpg"
        alt="RISC-V Out-of-Order processor pipeline block diagram and simulation"
      />
      
      <Fragment slot="note">
        {p.processor.note}
      </Fragment>
    </ProjectEntry>
  </div>
</section>
