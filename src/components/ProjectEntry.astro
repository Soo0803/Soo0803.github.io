---
interface Props {
  kicker: string;
  title: string;
  liveUrl?: string;
  meta: string;
  noteLabel?: string;
  lang?: 'en' | 'zh';
}

const { kicker, title, liveUrl, meta, noteLabel, lang = 'en' } = Astro.props;

const liveLabel = lang === 'en' ? "it's live →" : "已上线 →";
---
<div class="row project-row reveal">
  <div class="body">
    <div class="project">
      <p class="kicker">{kicker}</p>
      <h3>
        {title}
        {liveUrl && (
          <a class="live" href={liveUrl} target="_blank" rel="noopener">{liveLabel}</a>
        )}
      </h3>
      <div class="prose">
        <slot />
      </div>
      
      <p class="meta">{meta}</p>
    </div>
  </div>
  
  {(noteLabel || Astro.slots.has('media')) && (
    <div class="side-col">
      {noteLabel && (
        <aside class="note">
          <span class="who">{noteLabel}</span>
          <slot name="note" />
        </aside>
      )}
      <slot name="media" />
    </div>
  )}
</div>
