---
import { translations } from '../i18n/translations';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = translations[lang].contact;
---
<section class="closing" id="resume">
  <div class="wrap">
    <div class="row reveal">
      <div class="body">
        <p class="eyebrow">{t.eyebrow}</p>
        <h2>{t.title}</h2>
        <p class="lede">{t.lede}</p>
        <nav class="links">
          <!-- EMAIL LINK -->
          <a href="mailto:weij0803@gmail.com">{t.emailMe}</a>
          <!-- GITHUB LINK (CORRECT) -->
          <a href="https://github.com/Soo0803" target="_blank" rel="noopener">github</a>
          <!-- LINKEDIN LINK (CORRECT) -->
          <a href="https://www.linkedin.com/in/wei-jie-soo-291921234" target="_blank" rel="noopener">linkedin</a>
          <!-- RESUME LINK (CORRECT) -->
          <a href="/SOO_WEI_JIE.pdf" target="_blank" rel="noopener">{t.downloadResume}</a>
        </nav>
      </div>
    </div>
  </div>
</section>
